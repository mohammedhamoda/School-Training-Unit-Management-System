{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SchoolTrainingUnit",
  "version": "0.1.0",
  "identifier": "com.trainingunitschool.system",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "SchoolTrainingUnit",
        "width": 800,
        "height": 600,
        "maximized": true
      }
    ],
    "security": {
      "csp": null,
      "capabilities": [
        {
          "identifier": "default",
          "description": "Default capability for SchoolTrainingUnit",
          "windows": ["main"],
        "permissions": [
          "core:default",
          "opener:default",
          "fs:default",
          "fs:allow-write-file",
          "fs:allow-read-file",
          "fs:allow-exists",
          {
            "identifier": "fs:allow-write-file",
            "allow": [{ "path": "$TEMP/**" }]
          },
          {
            "identifier": "fs:allow-read-file",
            "allow": [{ "path": "$TEMP/**" }]
          },
          {
            "identifier": "opener:allow-open-path",
            "allow": [{ "path": "$TEMP/**" }]
          }
        ]
        }
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}